# Copie para .env e preencha com valores reais.
# O arquivo .env NÃO vai para o GitHub (está no .gitignore).

# Aplicação
APP_NAME=CRM Piloto
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
SECRET_KEY=altere-esta-chave-secreta-em-producao-min-32-caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - URLs do Frontend (Hostinger)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://seudominio.com.br

# Oracle Database (XEPDB1 na VPS)
ORACLE_USER=crm_user
ORACLE_PASSWORD=sua_senha
ORACLE_HOST=IP_DA_SUA_VPS
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
# Formato: oracle+oracledb://user:pass@host:port/?service_name=XEPDB1

# E-mail (recuperação de senha)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=seu-email@seudominio.com.br
SMTP_PASSWORD=sua_senha_smtp
SMTP_FROM=CRM Piloto <noreply@seudominio.com.br>
SMTP_TLS=true

# URL do Frontend (links de recuperação de senha)
FRONTEND_URL=https://seudominio.com.br

# VPS
HOST=0.0.0.0
PORT=8000
